# AssistGen environment variables. Copy to .env and fill in real values.
# Do not commit real API keys, passwords, or local .env files.

# Observability
# Set to "true" to print one compact trace line per pipeline stage.
AGENT_TRACE=true

# LLM
AGENT_SERVICE=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Demo product data
PRODUCT_DATA_PATH=app/data/products.csv

# Session memory
# Redis is optional. If Redis is unavailable, AssistGen falls back to InMemorySessionStore.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_EXPIRE=3600
REDIS_CACHE_THRESHOLD=0.90
MEMORY_TTL_SECONDS=21600
MEMORY_RECENT_WINDOW_SIZE=6

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_PRODUCTS=assistgen_products
QDRANT_VECTOR_SIZE=512

# Embedding
# Local embedding works for offline demos. DashScope text-embedding-v4 is recommended for stronger retrieval.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=512
EMBEDDING_BATCH_SIZE=10
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_API_KEY=your_dashscope_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Reranker
# Leave empty to use local fusion fallback.
RERANKER_PROVIDER=
RERANKER_MODEL=gte-rerank-v2
RERANKER_API_URL=
RERANKER_API_KEY=your_reranker_api_key_here
RERANKER_TIMEOUT_SECONDS=30

# Neo4j, optional hidden graph fallback.
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=assistgen

# MySQL, optional account/history modules.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=assist_gen

# Vision model, optional.
VISION_API_KEY=your_vision_api_key_here
VISION_BASE_URL=https://api.deepseek.com
VISION_MODEL=deepseek-chat

# Ollama, optional local backend.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5
OLLAMA_REASON_MODEL=deepseek-r1
OLLAMA_AGENT_MODEL=qwen2.5
OLLAMA_EMBEDDING_MODEL=bge-m3
