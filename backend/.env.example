# AssistGen backend environment variables.
# Copy this file to the real .env used by your local backend and fill in private values.

# LLM
AGENT_SERVICE=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Vision model, optional
VISION_API_KEY=your_vision_api_key_here
VISION_BASE_URL=https://api.deepseek.com
VISION_MODEL=deepseek-chat

# Ollama, optional local backend
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5
OLLAMA_REASON_MODEL=deepseek-r1
OLLAMA_AGENT_MODEL=qwen2.5
OLLAMA_EMBEDDING_MODEL=bge-m3

# Search, optional
SERPAPI_KEY=your_serpapi_key_here
SEARCH_RESULT_COUNT=10

# MySQL, optional for account/history modules
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=assist_gen

# Neo4j, optional graph fallback
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=assistgen

# Redis, optional session memory
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_EXPIRE=3600
REDIS_CACHE_THRESHOLD=0.90

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_PRODUCTS=assistgen_products

# Agent trace
AGENT_TRACE=true
